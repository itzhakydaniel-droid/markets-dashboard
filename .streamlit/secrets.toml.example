# Copy this to .streamlit/secrets.toml for local use
# OR paste these values into Streamlit Community Cloud → App Settings → Secrets

FRED_API_KEY = "your_fred_api_key_here"
ANTHROPIC_API_KEY = "your_anthropic_key_here"
MAKE_WEBHOOK_URL = "https://hook.make.com/your_webhook_id_here"
DISCORD_WEBHOOK_URL = "https://discord.com/api/webhooks/your_webhook_here"
UNUSUAL_WHALES_API_KEY = "your_key_here"
REFRESH_INTERVAL_SECONDS = "300"
